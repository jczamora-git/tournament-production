# Database
DB_CLIENT=postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres

# Server
PORT=3000

# Admin authentication
ADMIN_TOKEN=your-secure-admin-token-here

# URLs (use Vercel domains while custom DNS is invalid)
FRONTEND_URL=https://jeiziproduction.vercel.app
ADMIN_URL=https://adminjeizi.vercel.app

# Local development (for Vite proxy, leave empty for same-origin in production)
# VITE_API_BASE_URL=http://localhost:3000

# Storage driver: local | supabase | r2
STORAGE_DRIVER=local

# Local storage
LOCAL_UPLOADS_DIR=server/uploads

# Cloudflare R2 (production — set STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cmo-tournament-assets
R2_PUBLIC_BASE_URL=https://assets.cmotournaments.live

# Supabase Storage (legacy — set STORAGE_DRIVER=supabase)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=jeizi-storage

# MySQL (if using locally)
# DB_CLIENT=mysql
# MYSQL_HOST=localhost
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=jeizi_production
# MYSQL_PORT=3306
